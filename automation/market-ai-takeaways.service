[Unit]
Description=Market AI Takeaways Refresh Service
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=root
WorkingDirectory=/var/www/valuation
Environment="PATH=/var/www/valuation/.venv/bin:/usr/local/bin:/usr/bin:/bin"
Environment="PYTHONUNBUFFERED=1"
EnvironmentFile=/var/www/valuation/.env
ExecStart=/var/www/valuation/.venv/bin/python3 -m backend.updater.market_ai_takeaways --refresh
StandardOutput=journal
StandardError=journal
