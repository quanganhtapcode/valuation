[Unit]
Description=Stock Derived Data Maintenance Timer
Requires=stock-fetch.service

[Timer]
# Chạy 4 lần/ngày để cập nhật security master và valuation cache.
# 00:00, 06:00, 12:00, 18:00 giờ máy chủ
OnCalendar=*-*-* 00,06,12,18:00:00
# Nếu miss schedule (VPS tắt), chạy ngay khi bật lại
Persistent=true
# Random delay 0-300s để tránh spike VCI API
RandomizedDelaySec=300

[Install]
WantedBy=timers.target
