# =============================================================
# Environment variables reference — copy to .env.local for dev
# =============================================================
#
# Domain architecture:
#   stock.quanganh.org  → Vercel (this Next.js app)
#   api.quanganh.org    → VPS nginx gateway (Flask :8000)
#
# For local development: copy this file to .env.local and adjust.
# For Vercel deployment: set BACKEND_API_URL and
#   NEXT_PUBLIC_BACKEND_WS_URL in the Vercel dashboard (or use
#   .env.production which is committed with the correct values).
# =============================================================

# ── Server-side only — Next.js API proxy calls this URL ─────────────────
# Production: VPS backend via nginx
BACKEND_API_URL=https://api.quanganh.org/v1/valuation
# Local dev: Flask running on localhost
BACKEND_API_URL_LOCAL=http://127.0.0.1:8000/api

# ── Client-side (NEXT_PUBLIC_ = baked into browser bundle) ──────────────
# Cached REST base: leave unset (defaults to "/api", proxied through Vercel).
# Set to absolute URL only if you want all browser REST to bypass Vercel.
# NEXT_PUBLIC_API_URL=

# Realtime REST base: direct backend for small no-store market endpoints.
# This avoids Vercel proxy latency for indices/top movers.
NEXT_PUBLIC_REALTIME_API_URL=https://api.quanganh.org/v1/valuation

# WebSocket: direct to backend (Vercel cannot proxy WebSocket connections)
# Must be an absolute wss:// or ws:// URL.
NEXT_PUBLIC_BACKEND_WS_URL=wss://api.quanganh.org/v1/valuation
# Local dev:
# NEXT_PUBLIC_BACKEND_WS_URL=ws://127.0.0.1:8000

# ── Server-side AI analysis generation ─────────────────────────────────
# Used by backend AI analysis providers. Never expose these as
# NEXT_PUBLIC_* values.
GEMMA_API_KEY=
# Default keeps current Gemma-first behavior and uses OpenRouter only as
# fallback when OPENROUTER_API_KEY is configured.
AI_PROVIDER_ORDER=gemma,openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_SITE_URL=https://stock.quanganh.org
OPENROUTER_APP_NAME=Vietnam Stock Valuation
